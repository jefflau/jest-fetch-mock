{
  "compilerOptions": {
    "module": "commonjs",
    "lib": [
      "es2015"
    ],
    "paths": {
      "jest-fetch-mock": [
        "./index.d.ts"
      ]
    },
    "types": [
      "node",
      "jest"
    ],
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  }
}
