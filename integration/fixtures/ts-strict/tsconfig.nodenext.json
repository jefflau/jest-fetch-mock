{
  "compilerOptions": {
    "strict": true,
    "target": "es2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "es2020"
    ],
    "skipLibCheck": false,
    "noEmit": true,
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "*.ts"
  ]
}
